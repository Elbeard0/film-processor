// Motor A pins
const int in1 = D2;  // Direction pin 1
const int in2 = D3;  // Direction pin 2

// Define total runtime in seconds
const unsigned long totalRunTime = 300;  // 5 minutes (300 seconds)

unsigned long startTime;

void setup() {
  pinMode(in1, OUTPUT);
  pinMode(in2, OUTPUT);
  Serial.begin(9600);
  
  // Start motor sequence immediately on power up
  startTime = millis();
  Serial.println("Motor sequence started!");
}

void loop() {
  unsigned long elapsedTime = (millis() - startTime) / 1000;  // Convert to seconds
  
  // Check if total runtime has been exceeded
  if (elapsedTime >= totalRunTime) {
    motorStop();
    Serial.println("Total runtime reached. Motor stopped.");
    while(1);  // Halt program
  }
  
  // Calculate position within 30-second cycle (15 forward + 15 reverse)
  unsigned long cycleTime = elapsedTime % 30;
  
  if (cycleTime < 15) {
    // Forward for 15 seconds
    motorForward();
  } else {
    // Reverse for 15 seconds
    motorBackward();
  }
  
  delay(100);  // Check every 100ms
}

void motorForward() {
  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  Serial.println("Motor: Forward");
}

void motorBackward() {
  digitalWrite(in1, LOW);
  digitalWrite(in2, HIGH);
  Serial.println("Motor: Backward");
}

void motorStop() {
  digitalWrite(in1, LOW);
  digitalWrite(in2, LOW);
  Serial.println("Motor: Stop");
}
